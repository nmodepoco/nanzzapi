    "/image/wallpaper": {
      "get": {
        "summary": "Wallpaper",
        "description": "Random images from WallpaperFlare based on search query",
        "tags": ["Image"],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": false,
            "description": "Search query (e.g., Naruto, Anime, Landscape)",
            "schema": { "type": "string", "example": "Naruto" }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Number of images to return (default 5, max 10)",
            "schema": { "type": "integer", "example": 5 }
          }
        ]
      }
    },
    "/news/detik": {
